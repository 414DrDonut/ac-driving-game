{
  "name": "ac-highway-dodging-game",
  "version": "0.1.0",
  "description": "A fast-paced arcade game where you dodge traffic on the highway",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "start": "node dist/server/index.js",
    "server:dev": "ts-node src/server/index.ts",
    "server:build": "tsc --project tsconfig.server.json",
    "client:dev": "webpack serve --mode development --config webpack.dev.js",
    "client:build": "webpack --mode production --config webpack.prod.js",
    "build": "npm run server:build && npm run client:build",
    "test": "jest",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": ["game", "arcade", "driving", "traffic", "dodge"],
  "author": "414DrDonut",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.5.4",
    "three": "^r150",
    "typescript": "^5.0.0",
    "dotenv": "^16.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.17",
    "ts-node": "^10.9.1",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "ts-loader": "^9.4.2",
    "concurrently": "^8.0.1",
    "jest": "^29.5.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "eslint": "^8.40.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0"
  }
}
